

# =============================================================================
# scrapy_moneyforward_pk .gitignore
# 方針:
# - 秘密情報はコミットしない
# - 実行ごとに変わる runtime データはコミットしない
# - 仮想環境やキャッシュなどのローカル生成物はコミットしない
# - 共有したいテンプレートや fixture は除外しない
# =============================================================================

# -----------------------------------------------------------------------------
# Environment files
# .env は実運用の秘密情報を含むため除外する。
# ただし .env.example は共有テンプレートとして追跡する。
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Python virtual environments and caches
# -----------------------------------------------------------------------------
.venv-win/
.venv-wsl/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.ruff_cache/

# -----------------------------------------------------------------------------
# Runtime data
# クロール結果、session state、採取HTML、実行ログなど、
# 実行のたびに更新されるファイル群。
# .gitkeep は空ディレクトリ維持のため追跡する。
# -----------------------------------------------------------------------------
runtime/**
!runtime/
!runtime/*/
!runtime/**/.gitkeep
!runtime/output/inspector/

# -----------------------------------------------------------------------------
# data/ sample captures
# data 配下はフォルダ構成と README だけ共有し、
# 採取した HTML や調査データ本体はコミットしない。
# .gitkeep は空ディレクトリ維持のため追跡する。
# -----------------------------------------------------------------------------
data/**
!data/
!data/*/
!data/**/*.md
!data/*/.gitkeep

# -----------------------------------------------------------------------------
# Logs and debug artifacts
# -----------------------------------------------------------------------------
*.log
debug_*.png

# -----------------------------------------------------------------------------
# Editor / local workspace files
# 個人用の作業メモやエディタ設定は共有しない。
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# 作業ディレクトリ
# -----------------------------------------------------------------------------
.work/
.tmp/

# -----------------------------------------------------------------------------
# Claude Code project-local 状態
# 共有したい設定 (settings / agents / skills / commands / hooks) のみ追跡。
# それ以外 (worktrees / lock / schedule / transcripts 等の生成物) は除外。
# -----------------------------------------------------------------------------
.claude/*
!.claude/settings.json
!.claude/agents/
!.claude/skills/
!.claude/commands/
!.claude/hooks/

# -----------------------------------------------------------------------------
# tools/passkey/state — 認証クレデンシャル・セッション（秘密情報）
# screenshots/ は手順説明用スクショとして追跡する。
# -----------------------------------------------------------------------------
tools/passkey/state/**
!tools/passkey/state/.gitkeep

# -----------------------------------------------------------------------------
# Fixtures that should remain tracked
# tests/fixtures 配下の JSON はテスト資産として共有する。
# -----------------------------------------------------------------------------
!tests/fixtures/**/*.json

# -----------------------------------------------------------------------------
# Secrets / credentials
# Issue #43: per-site/per-account login credentials live in config/.
# Issue #40: crawl runner reads accounts.yaml for orchestration.
# Only the *.example.yaml templates may be committed.
# -----------------------------------------------------------------------------
config/accounts.yaml
config/segregated_asset.yaml
config/account_types.yaml
config/*.local.yaml
config/secrets/
