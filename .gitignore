# =============================================================================
# workbench .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment files
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Python virtual environments
# スタンドアロン使用時に生成される venv。
# -----------------------------------------------------------------------------
.venv-win/
.venv-wsl/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Runtime data
# スタンドアロン使用時に cleanup_rules / archive_rules が参照するディレクトリ。
# -----------------------------------------------------------------------------
/data/
/logs/
/work/
/runtime/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
