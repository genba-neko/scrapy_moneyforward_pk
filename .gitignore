# =============================================================================
# workbench .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment files
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Python virtual environments
# スタンドアロン使用時に生成される venv。
# -----------------------------------------------------------------------------
.venv-win/
.venv-wsl/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Runtime data
# スタンドアロン使用時に cleanup_rules / archive_rules が参照するディレクトリ。
# -----------------------------------------------------------------------------
/data/
/logs/
/work/
/runtime/
# Issue #43: defensively ignore src/runtime as well in case PROJECT_ROOT
# resolution regresses and state files end up under src/.
src/runtime/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# プロジェクト設定
# -----------------------------------------------------------------------------
scheduled_tasks.lock

# -----------------------------------------------------------------------------
# Secrets / credentials
# Issue #43: per-site/per-account login credentials live in config/.
# Only the *.example.yaml templates may be committed.
# -----------------------------------------------------------------------------
config/accounts.yaml
config/*.local.yaml
config/secrets/
