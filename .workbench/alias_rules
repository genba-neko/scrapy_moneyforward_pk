# NAME        COMMAND  [ # DESCRIPTION ]
# - NAME: 実行するコマンド名
# - COMMAND: 実行するコマンド。@args で引数を受け取れる。
#            以下の環境変数が両プロファイルで利用可能:
#              $VENV_PYTHON  : venv の python インタープリタ
#              $PROJECT_ROOT : プロジェクトルートパス
# - DESCRIPTION: help / show-workspace-menu に表示される説明文

format        $VENV_PYTHON -m ruff format . ; $VENV_PYTHON -m ruff check --fix .  # ruff で整形 → lint 自動修正
lint          $VENV_PYTHON -m pyright ; $VENV_PYTHON -m ruff check .  # 型チェック → lint
test-unit     $VENV_PYTHON -m pytest -k unit @args  # unit テストのみ実行
test-all      $VENV_PYTHON -m pytest @args  # 全テスト実行
test-full     $VENV_PYTHON -m pytest  --cov --cov-report=term-missing @args  # カバレッジ付き
crawl-list    cd $PROJECT_ROOT/src ; $VENV_PYTHON -m moneyforward_pk.crawl_runner --list @args  # 起動予定一覧 (実行しない)
crawl         cd $PROJECT_ROOT/src ; $VENV_PYTHON -m moneyforward_pk.crawl_runner @args  # crawl_runner 実行 (--site / --type で絞り込み可)
crawl-trans   cd $PROJECT_ROOT/src ; $VENV_PYTHON -m moneyforward_pk.crawl_runner --type transaction @args  # transaction のみ全 site/account
crawl-asset   cd $PROJECT_ROOT/src ; $VENV_PYTHON -m moneyforward_pk.crawl_runner --type asset_allocation @args  # asset_allocation のみ全 site/account
crawl-acct    cd $PROJECT_ROOT/src ; $VENV_PYTHON -m moneyforward_pk.crawl_runner --type account @args  # account のみ全 site/account
