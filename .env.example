# MoneyForward credentials
SITE_LOGIN_USER=your-email@example.com
SITE_LOGIN_PASS=your-password
SITE_LOGIN_ALT_USER=
SITE_PAST_MONTHS=12

# Playwright
MONEYFORWARD_HEADLESS=true
MONEYFORWARD_LOGIN_MAX_RETRY=2

# JSON output (per-spider JSON Lines; under PROJECT_ROOT only)
# OUTPUT_DIR は省略時 runtime/output/ になる。プロジェクトルート配下のみ許可。
OUTPUT_DIR=
OUTPUT_FILENAME_TEMPLATE={spider}_{date:%Y%m%d}.jsonl
# OUTPUT_RETENTION_DAYS: open_spider 時に同一スパイダーの古い jsonl を削除する閾値 (日)
OUTPUT_RETENTION_DAYS=14

# Slack notifications (空のまま運用すると extension は no-op)
SLACK_INCOMING_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
LOG_FILE_ENABLED=false
LOG_FILE_PATH=runtime/logs/moneyforward_pk.log
