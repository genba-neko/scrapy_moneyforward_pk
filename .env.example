# -----------------------------------------------------------------------------
# Secrets backend (省略時は env mode: config/accounts.yaml を使用)
# -----------------------------------------------------------------------------
# 値: env (開発標準: 下記 secrets を .env から直接読込)
#     bitwarden (Bitwarden Secrets Manager から取得)
SECRETS_BACKEND=env

# -----------------------------------------------------------------------------
# Bitwarden Secrets Manager (SECRETS_BACKEND=bitwarden 時 / tools/secrets/bws_tool.py 使用時)
# BWS に登録する対象キー (MONEYFORWARD_ prefix を付けて登録すること):
#   MONEYFORWARD_ACCOUNTS                    — accounts.yaml 相当の JSON (必須)
#   MONEYFORWARD_SLACK_INCOMING_WEBHOOK_URL  — Slack webhook URL (任意)
# -----------------------------------------------------------------------------
# machine account の access token (read-write 兼用、1 個)
BWS_ACCESS_TOKEN=REPLACE_ME
# Bitwarden organization の UUID
ORGANIZATION_ID=REPLACE_ME
# 登録先 project の UUID (tools/secrets/bws_tool.py register 時必須)
BWS_PROJECT_ID=REPLACE_ME
# リージョン (US デフォルト・EU 利用時のみ書き換え)
BWS_API_URL=https://api.bitwarden.com
BWS_IDENTITY_URL=https://identity.bitwarden.com

# -----------------------------------------------------------------------------
# サイト認証情報 [開発・デバッグ用 / 通常運用では使用しない]
# 通常運用: config/accounts.yaml (per-site / per-account) を使用。
# [Bitwarden 対象] BWS キー: MONEYFORWARD_ACCOUNTS
# 詳細: config/accounts.example.yaml 参照。
# -----------------------------------------------------------------------------
# SITE_LOGIN_USER / SITE_LOGIN_PASS は ``scrapy crawl <name>`` 単発実行時のみ
# フォールバックとして参照される。crawl_runner 経由では無視される。
SITE_LOGIN_USER=
SITE_LOGIN_PASS=

# -----------------------------------------------------------------------------
# scrapy_moneyforwardの設定
# scrapy_moneyforward の動作に関する設定。
# -----------------------------------------------------------------------------
# ページ取得対象の過去月数 (default: 12)
SITE_PAST_MONTHS=12

# -----------------------------------------------------------------------------
# Playwright
# -----------------------------------------------------------------------------
# ブラウザを headless で起動するか (default: true)
MONEYFORWARD_HEADLESS=true
# セッション切れ時の再ログイン最大試行回数 (default: 2)
MONEYFORWARD_LOGIN_MAX_RETRY=2

# -----------------------------------------------------------------------------
# JSON 出力 (PROJECT_ROOT 配下に 3 ファイル集約)
# OUTPUT_DIR は省略時 runtime/output/。プロジェクトルート配下のみ許可。
# -----------------------------------------------------------------------------
OUTPUT_DIR=
OUTPUT_FILENAME_TEMPLATE=moneyforward_{spider_type}.json

# -----------------------------------------------------------------------------
# Slack 通知 (空のまま運用すると extension は no-op)
# [Bitwarden 対象] BWS キー: MONEYFORWARD_SLACK_INCOMING_WEBHOOK_URL
# -----------------------------------------------------------------------------
SLACK_INCOMING_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# ログ
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_ENABLED=false
LOG_FILE_PATH=runtime/logs/moneyforward.log

# -----------------------------------------------------------------------------
# HTML inspector [開発・デバッグ用 / 通常運用では使用しない]
# 有効時 runtime/inspect/ に各レスポンス HTML を dump。
# -----------------------------------------------------------------------------
MONEYFORWARD_HTML_INSPECTOR=false
MONEYFORWARD_HTML_INSPECTOR_DIR=

# -----------------------------------------------------------------------------
# Python bytecode / __pycache__ 生成抑止
# load_dotenv() では効果なし（Python 起動後のため）。
# job_runner.sh が自動設定する。手動実行時はシェルで事前に設定すること:
#   export PYTHONDONTWRITEBYTECODE=1  # bash/zsh
#   $env:PYTHONDONTWRITEBYTECODE=1    # PowerShell
# -----------------------------------------------------------------------------
PYTHONDONTWRITEBYTECODE=1
