# MoneyForward credentials
SITE_LOGIN_USER=your-email@example.com
SITE_LOGIN_PASS=your-password
SITE_LOGIN_ALT_USER=
SITE_PAST_MONTHS=12

# Playwright
MONEYFORWARD_HEADLESS=true
MONEYFORWARD_LOGIN_MAX_RETRY=2

# DynamoDB (optional; leave blank to disable pipeline)
DYNAMODB_TABLE_NAME=
DYNAMODB_BATCH_N=10
DYNAMODB_PUT_DELAY=3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1

# Slack notifications
SLACK_INCOMING_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
LOG_FILE_ENABLED=false
LOG_FILE_PATH=runtime/logs/moneyforward_pk.log
